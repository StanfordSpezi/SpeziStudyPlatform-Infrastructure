      "credentials": [{ "type": "password", "value": "password123", "temporary": false }],
      "realmRoles": ["spezistudyplatform-authorized-users", "spezistudyplatform-researcher", "ArgoCDAdmins"],
      "groups": ["/Stanford Biodesign Digital Health/admin", "/ArgoCDAdmins"]
    },
    {
      "username": "jane@example.com",
